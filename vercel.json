{
  "version": 2,
  "crons": [
    {
      "path": "/api/push/cron",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/pgwos/dist/public/$1"
    }
  ]
}
